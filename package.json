{
  "name": "@weapon/monorepo",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*",
      "../toolkit/packages/*"
    ],
    "catalog": {
      "@ark/schema": "0.56.0",
      "arktype": "2.1.29",
      "@types/bun": "1.3.12",
      "regexparam": "3.0.0",
      "@tanstack/react-query": "5"
    }
  },
  "author": {
    "name": "Sigitex",
    "url": "http://github.com/sigitex"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sigitex/weapon.git"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3",
    "multi-semantic-release": "^3.1.0",
    "@markwylde/semantic-release-gitea": "^2.2.0",
    "@semantic-release/exec": "^7.0.3"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "oxlint",
